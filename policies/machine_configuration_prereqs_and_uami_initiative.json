{
  "properties": {
    "displayName": "Azure VM prerequisites for Machine Configuration (system identity + extension) + required UAMI for package access",
    "policyType": "Custom",
    "description": "Initiative that prepares Azure Windows VMs for Machine Configuration by enabling system-assigned managed identity, deploying the Machine Configuration extension, and attaching a required user-assigned managed identity (UAMI) used to download packages from private storage.",
