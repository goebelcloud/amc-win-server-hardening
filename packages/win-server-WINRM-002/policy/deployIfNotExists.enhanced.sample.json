{
  "properties": {
    "displayName": "tkmx-cm-windows-server-hardening-WINRM-002 - Disallow Basic authentication (Machine Configuration)",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Applies Windows Server hardening setting: Windows Components\\Windows Remote Management (WinRM)\\WinRM Service -> Disallow Basic authentication = Basic = Disabled (use Kerberos/cert). (ControlId: win-server-WINRM-002)",
    "metadata": {
      "category": "Guest Configuration",
      "version": "1.0.0",
      "guestConfiguration": {
        "name": "win-server-WINRM-002",
        "version": "1.0.0",
        "contentType": "Custom",
        "contentUri": "__CONTENT_URI__",
        "contentHash": "__CONTENT_HASH__",
        "contentManagedIdentity": "__UAMI_RESOURCE_ID__",
        "configurationParameter": {}
      }
    },
    "parameters": {
      "requiredUserAssignedIdentityResourceId": {
        "type": "String",
        "metadata": {
          "displayName": "Required UAMI resource ID",
          "description": "UAMI that must be attached to the VM (used to download Machine Configuration packages)."
        },
        "defaultValue": "__UAMI_RESOURCE_ID__"
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable this policy."
        },
        "allowedValues": [
          "DeployIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "assignmentType": {
        "type": "String",
        "metadata": {
          "displayName": "Machine Configuration assignment type",
          "description": "How Machine Configuration should evaluate/apply the setting: Audit, ApplyAndMonitor, or ApplyAndAutoCorrect."
        },
        "allowedValues": [
          "Audit",
          "ApplyAndMonitor",
          "ApplyAndAutoCorrect"
        ],
        "defaultValue": "ApplyAndAutoCorrect"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Compute/virtualMachines"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Compute/virtualMachines/osProfile.windowsConfiguration",
                "exists": "true"
              },
              {
                "field": "Microsoft.Compute/virtualMachines/storageProfile.osDisk.osType",
                "like": "Windows*"
              }
            ]
          },
          {
            "anyOf": [
              {
                "allOf": [
                  {
                    "field": "Microsoft.Compute/imageOffer",
                    "like": "WindowsServer*"
                  },
                  {
                    "anyOf": [
                      {
                        "field": "Microsoft.Compute/imageSKU",
                        "like": "2016*"
                      },
                      {
                        "field": "Microsoft.Compute/imageSKU",
                        "like": "2019*"
                      },
                      {
                        "field": "Microsoft.Compute/imageSKU",
                        "like": "2022*"
                      },
                      {
                        "field": "Microsoft.Compute/imageSKU",
                        "like": "2025*"
                      }
                    ]
                  }
                ]
              },
              {
                "field": "Microsoft.Compute/imageOffer",
                "like": "*WS2016*"
              },
              {
                "field": "Microsoft.Compute/imageOffer",
                "like": "*WS2019*"
              },
              {
                "field": "Microsoft.Compute/imageOffer",
                "like": "*WS2022*"
              },
              {
                "field": "Microsoft.Compute/imageOffer",
                "like": "*WS2025*"
              }
            ]
          },
          {
            "field": "identity.type",
            "contains": "SystemAssigned"
          },
          {
            "field": "identity.userAssignedIdentities",
            "containsKey": "[parameters('requiredUserAssignedIdentityResourceId')]"
          },
          {
            "count": {
              "field": "Microsoft.Compute/virtualMachines/extensions[*]",
              "where": {
                "allOf": [
                  {
                    "field": "Microsoft.Compute/virtualMachines/extensions[*].publisher",
                    "equals": "Microsoft.GuestConfiguration"
                  },
                  {
                    "field": "Microsoft.Compute/virtualMachines/extensions[*].type",
                    "equals": "ConfigurationforWindows"
                  },
                  {
                    "field": "Microsoft.Compute/virtualMachines/extensions[*].provisioningState",
                    "equals": "Succeeded"
                  }
                ]
              }
            },
            "greater": 0
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "type": "Microsoft.GuestConfiguration/guestConfigurationAssignments",
          "roleDefinitionIds": [
            "/providers/microsoft.authorization/roleDefinitions/b24988ac-6180-42a0-ab88-20f7382dd24c"
          ],
          "deployment": {
            "properties": {
              "mode": "incremental",
              "parameters": {
                "vmName": {
                  "value": "[field('name')]"
                },
                "location": {
                  "value": "[field('location')]"
                },
                "assignmentType": {
                  "value": "[parameters('assignmentType')]"
                }
              },
              "template": {
                "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                "contentVersion": "1.0.0.0",
                "parameters": {
                  "vmName": {
                    "type": "string"
                  },
                  "location": {
                    "type": "string"
                  },
                  "assignmentType": {
                    "type": "string"
                  }
                },
                "resources": [
                  {
                    "apiVersion": "2021-01-25",
                    "type": "Microsoft.Compute/virtualMachines/providers/guestConfigurationAssignments",
                    "name": "[concat(parameters('vmName'), '/Microsoft.GuestConfiguration/win-server-WINRM-002')]",
                    "location": "[parameters('location')]",
                    "properties": {
                      "guestConfiguration": {
                        "name": "win-server-WINRM-002",
                        "version": "1.0.0",
                        "contentUri": "__CONTENT_URI__",
                        "contentHash": "__CONTENT_HASH__",
                        "contentManagedIdentity": "__UAMI_RESOURCE_ID__",
                        "assignmentType": "[parameters('assignmentType')]",
                        "configurationParameter": []
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}