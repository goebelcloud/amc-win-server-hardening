{
  "properties": {
    "displayName": "tkmx-cm-windows-server-hardening-DEF-001 - Real-time protection (Machine Configuration)",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Applies Windows Server hardening setting: Windows Components\\Microsoft Defender Antivirus -> Real-time protection = Enabled (do not disable real-time monitoring). (ControlId: win-server-DEF-001)",
    "metadata": {
      "category": "Guest Configuration",
      "version": "1.0.0",
      "guestConfiguration": {
        "name": "win-server-DEF-001",
        "version": "1.0.0",
        "contentType": "Custom",
        "contentUri": "__CONTENT_URI__",
        "contentHash": "__CONTENT_HASH__",
        "contentManagedIdentity": "__UAMI_RESOURCE_ID__",
        "configurationParameter": {}
      }
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable this policy."
        },
        "allowedValues": [
          "DeployIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "assignmentType": {
        "type": "String",
        "metadata": {
          "displayName": "Machine Configuration assignment type",
          "description": "How Machine Configuration should evaluate/apply the setting: Audit, ApplyAndMonitor, or ApplyAndAutoCorrect."
        },
        "allowedValues": [
          "Audit",
          "ApplyAndMonitor",
          "ApplyAndAutoCorrect"
        ],
        "defaultValue": "ApplyAndAutoCorrect"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Compute/virtualMachines"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Compute/virtualMachines/osProfile.windowsConfiguration",
                "exists": "true"
              },
              {
                "field": "Microsoft.Compute/virtualMachines/storageProfile.osDisk.osType",
                "like": "Windows*"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "type": "Microsoft.GuestConfiguration/guestConfigurationAssignments",
          "roleDefinitionIds": [
            "/providers/microsoft.authorization/roleDefinitions/b24988ac-6180-42a0-ab88-20f7382dd24c"
          ],
          "deployment": {
            "properties": {
              "mode": "incremental",
              "parameters": {
                "vmName": {
                  "value": "[field('name')]"
                },
                "location": {
                  "value": "[field('location')]"
                },
                "assignmentType": {
                  "value": "[parameters('assignmentType')]"
                }
              },
              "template": {
                "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                "contentVersion": "1.0.0.0",
                "parameters": {
                  "vmName": {
                    "type": "string"
                  },
                  "location": {
                    "type": "string"
                  },
                  "assignmentType": {
                    "type": "string"
                  }
                },
                "resources": [
                  {
                    "apiVersion": "2021-01-25",
                    "type": "Microsoft.Compute/virtualMachines/providers/guestConfigurationAssignments",
                    "name": "[concat(parameters('vmName'), '/Microsoft.GuestConfiguration/win-server-DEF-001')]",
                    "location": "[parameters('location')]",
                    "properties": {
                      "guestConfiguration": {
                        "name": "win-server-DEF-001",
                        "version": "1.0.0",
                        "contentUri": "__CONTENT_URI__",
                        "contentHash": "__CONTENT_HASH__",
                        "contentManagedIdentity": "__UAMI_RESOURCE_ID__",
                        "assignmentType": "[parameters('assignmentType')]",
                        "configurationParameter": []
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}