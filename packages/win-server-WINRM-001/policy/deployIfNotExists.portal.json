{
  "displayName": "tkmx-cm-windows-server-hardening-WINRM-001 - Allow unencrypted traffic (Machine Configuration)",
  "policyType": "Custom",
  "mode": "Indexed",
  "description": "Applies Windows Server hardening setting: Windows Components\\Windows Remote Management (WinRM)\\WinRM Service -> Allow unencrypted traffic = Disabled. (ControlId: win-server-WINRM-001)",
  "metadata": {
    "category": "Guest Configuration",
    "version": "1.0.0",
    "guestConfiguration": {
      "name": "win-server-WINRM-001",
      "version": "1.0.0",
      "contentType": "Custom",
      "contentUri": "__CONTENT_URI__",
      "contentHash": "__CONTENT_HASH__",
      "contentManagedIdentity": "__UAMI_RESOURCE_ID__",
      "configurationParameter": {}
    },
    "requiredProviders": [
      "Microsoft.GuestConfiguration"
    ]
  },
  "parameters": {
    "effect": {
      "type": "String",
      "metadata": {
        "displayName": "Effect",
        "description": "Enable or disable this policy."
      },
      "allowedValues": [
        "DeployIfNotExists",
        "Disabled"
      ],
      "defaultValue": "DeployIfNotExists"
    },
    "assignmentType": {
      "type": "String",
      "metadata": {
        "displayName": "Machine Configuration assignment type",
        "description": "How Machine Configuration should evaluate/apply the setting: Audit, ApplyAndMonitor, or ApplyAndAutoCorrect."
      },
      "allowedValues": [
        "Audit",
        "ApplyAndMonitor",
        "ApplyAndAutoCorrect"
      ],
      "defaultValue": "ApplyAndAutoCorrect"
    }
  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.Compute/virtualMachines"
        },
        {
          "anyOf": [
            {
              "field": "Microsoft.Compute/virtualMachines/osProfile.windowsConfiguration",
              "exists": "true"
            },
            {
              "field": "Microsoft.Compute/virtualMachines/storageProfile.osDisk.osType",
              "like": "Windows*"
            }
          ]
        },
        {
          "field": "Microsoft.Compute/imageOffer",
          "like": "WindowsServer*"
        },
        {
          "anyOf": [
            {
              "field": "Microsoft.Compute/imageSku",
              "like": "2016*"
            },
            {
              "field": "Microsoft.Compute/imageSku",
              "like": "2019*"
            },
            {
              "field": "Microsoft.Compute/imageSku",
              "like": "2022*"
            },
            {
              "field": "Microsoft.Compute/imageSku",
              "like": "2025*"
            }
          ]
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]",
      "details": {
        "type": "Microsoft.GuestConfiguration/guestConfigurationAssignments",
        "roleDefinitionIds": [
          "/providers/Microsoft.Authorization/roleDefinitions/088ab73d-1256-47ae-bea9-9de8e7131f31"
        ],
        "deployment": {
          "properties": {
            "mode": "incremental",
            "parameters": {
              "vmName": {
                "value": "[field('name')]"
              },
              "location": {
                "value": "[field('location')]"
              },
              "assignmentType": {
                "value": "[parameters('assignmentType')]"
              },
              "assignmentName": {
                "value": "[concat('win-server-WINRM-001$pid', uniqueString(policy().assignmentId, policy().definitionReferenceId))]"
              }
            },
            "template": {
              "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
              "contentVersion": "1.0.0.0",
              "parameters": {
                "vmName": {
                  "type": "string"
                },
                "location": {
                  "type": "string"
                },
                "assignmentType": {
                  "type": "string"
                },
                "assignmentName": {
                  "type": "string"
                }
              },
              "resources": [
                {
                  "apiVersion": "2024-04-05",
                  "type": "Microsoft.Compute/virtualMachines/providers/guestConfigurationAssignments",
                  "name": "[concat(parameters('vmName'), '/Microsoft.GuestConfiguration/', parameters('assignmentName'))]",
                  "location": "[parameters('location')]",
                  "properties": {
                    "guestConfiguration": {
                      "name": "win-server-WINRM-001",
                      "version": "1.0.0",
                      "contentUri": "__CONTENT_URI__",
                      "contentHash": "__CONTENT_HASH__",
                      "contentManagedIdentity": "__UAMI_RESOURCE_ID__",
                      "assignmentType": "[parameters('assignmentType')]",
                      "configurationParameter": [],
                      "contentType": "Custom"
                    }
                  }
                }
              ]
            }
          }
        },
        "name": "[concat('win-server-WINRM-001$pid', uniqueString(policy().assignmentId, policy().definitionReferenceId))]",
        "existenceCondition": {
          "field": "Microsoft.GuestConfiguration/guestConfigurationAssignments/complianceStatus",
          "equals": "Compliant"
        },
        "evaluationDelay": "AfterProvisioningSuccess"
      }
    }
  }
}
